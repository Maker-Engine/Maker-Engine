<?xml version="1.0" encoding="utf-8"?>
<project>

    <!-- Project Info -->
    <meta 
        title="Maker Engine"
        package="maker.engine"
        version="0.1.0"
        company="Maker Engine Team" 
    />

    <!-- Window Settings -->
    <window 
        width="1280"
        height="720"
        fps="60"
        background="#000000"
        resizable="true"
    />

    <!-- Source -->
    <source path="source" />

    <!-- Assets -->
    <assets path="assets" rename="assets" />
    <assets path="mods" rename="mods" if="desktop" />

    <!-- Libraries -->
    <haxelib name="lime" />
    <haxelib name="openfl" />

    <!-- Optional Lua Support -->
    <!--
    <haxelib name="linc_luajit" />
    -->

    <!-- Defines -->
    <define name="desktop" />
    <define name="maker_engine" />

    <!-- Application -->
    <app main="Main" path="export" file="MakerEngine" />

</project>